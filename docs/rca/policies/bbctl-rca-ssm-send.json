{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RunShellViaSSM",
      "Effect": "Allow",
      "Action": [
        "ssm:SendCommand",
        "ssm:GetCommandInvocation",
        "ssm:DescribeInstanceInformation",
        "ssm:ListCommandInvocations"
      ],
      "Resource": "*",
      "Condition": {
        "StringEqualsIfExists": {
          "ssm:DocumentName": [
            "AWS-RunShellScript"
          ]
        }
      }
    }
  ]
}
